{
    "name": "fabriq/skeleton",
    "description": "Fabriq starter project — a ready-to-use scaffold for building Swoole-powered applications with multi-tenancy, realtime, queues, and per-tenant frontend serving.",
    "type": "project",
    "license": "MIT",
    "minimum-stability": "stable",
    "prefer-stable": true,
    "require": {
        "php": ">=8.2",
        "ext-swoole": "*",
        "ext-json": "*",
        "ext-mbstring": "*",
        "fabriq/kernel": "^1.0",
        "fabriq/storage": "^1.0",
        "fabriq/http": "^1.0",
        "fabriq/tenancy": "^1.0",
        "fabriq/realtime": "^1.0",
        "fabriq/queue": "^1.0",
        "fabriq/events": "^1.0",
        "fabriq/security": "^1.0",
        "fabriq/observability": "^1.0",
        "fabriq/orm": "^1.0"
    },
    "suggest": {
        "fabriq/streaming": "Live streaming add-on (WebRTC, HLS transcoding, chat moderation)",
        "fabriq/gaming": "Game server add-on (tick loop, matchmaking, UDP protocol, state sync)"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "serve": "php bin/fabriq serve",
        "processor": "php bin/fabriq processor",
        "scheduler": "php bin/fabriq scheduler"
    },
    "config": {
        "sort-packages": true
    }
}
